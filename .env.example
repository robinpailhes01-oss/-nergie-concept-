# Supabase (optionnel — app fonctionne en mode démo sans)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Maps Platform — clé unique pour Solar, Geocoding et Static Maps
# Serveur : appels Solar/Geocoding (clé secrète recommandée)
GOOGLE_SOLAR_API_KEY=your-google-api-key
# Client : affichage des photos satellite (Static Maps API)
# Peut être la même valeur — restreindre par "Référents HTTP" sur la console Google
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-api-key

# URL publique de l'app (pour les liens partagés)
NEXT_PUBLIC_APP_URL=http://localhost:3000
